# =============================================================================
# BẢN MẪU .env.docker — PRODUCTION: trohub.online + api.trohub.online (HTTPS)
# =============================================================================
# Sao chép file này thành .env.docker trên server (cùng thư mục docker-compose.yml),
# điền secret thật, rồi:
#   docker compose --env-file .env.docker up --build -d
#
# Kiến trúc (Cloudflare Tunnel → localhost):
#   https://trohub.online      → WEB_PORT (8080)
#   https://api.trohub.online  → API_PORT (5001)
#
# Google Cloud Console → OAuth Client (Web) → Authorized JavaScript origins:
#   https://trohub.online
#   (nếu dùng www: thêm https://www.trohub.online HOẶC redirect www → apex cho khớp CLIENT_URL)
#
# Biến VITE_* chỉ có hiệu lực sau khi build lại image web (docker compose up --build).
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=phongtroxanh
POSTGRES_USER=postgres
POSTGRES_PASSWORD=DAT_MAT_KHAU_DB_MANH_KHONG_DUNG_CHANGEME

# Tuỳ chọn: đổi cổng Postgres publish ra host (mặc định compose: 5432)
# POSTGRES_PORT=5432

# Cổng Docker publish — cloudflared / nginx reverse proxy trỏ vào đây
API_PORT=5001
WEB_PORT=8080

# --- Frontend (Vite — embed tại thời điểm build) ---
VITE_SERVER_URL=https://api.trohub.online/api/v1
VITE_CLIENT_GG_ID=
VITE_DROPBOX_API=
VITE_EXCHANGERATE_API=
VITE_PAYPAL_CLIENT_ID=
VITE_PRICE_OF_POST_PER_DAY=

# --- Backend ---
PORT=5001
NODE_ENV=production

# CORS: phải khớp Origin trình duyệt (https, không / cuối). Nhiều origin: cách nhau bằng dấu phẩy
# CLIENT_URL=https://trohub.online,https://www.trohub.online
CLIENT_URL=https://trohub.online

# Sau thanh toán VNPay/MoMo redirect user về frontend (route React)
CLIENT_PAYMENT_RETURN_URL=https://trohub.online/thanh-toan/

JWT_SECRET=DAT_CHUOI_NGAY_NHIEN_TOI_THIEU_32_BYTE

DB_DIALECT=postgres
DB_SSL=false

# DB_* dưới đây do docker-compose ghi đè khi dùng service postgres (thường không cần sửa trong file này)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=phongtroxanh
# DB_USER=postgres
# DB_PASSWORD= (trùng POSTGRES_PASSWORD qua compose)

# --- SMTP (email; để trống nếu chưa dùng) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- VNPay (production) ---
# VNP_URL: URL thanh toán do VNPay cấp (sandbox vs production khác nhau)
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=
VNP_RETURN_URL=https://api.trohub.online/api/v1/payment/vnpay-return
VNP_BANKCODE=

# --- MoMo ---
# MOMO_ENDPOINT: sandbox https://test-payment.momo.vn/v2/gateway/api/create | production theo tài liệu MoMo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=
MOMO_STORE_ID=
MOMO_ENDPOINT=
# Bắt buộc trỏ API (GET momo-return); không dùng URL frontend /thanh-toan/
MOMO_REDIRECT_URL=https://api.trohub.online/api/v1/payment/momo-return
MOMO_IPN_URL=https://api.trohub.online/api/v1/payment/momo-ipn

# --- Twilio SMS OTP (tên biến trong code là TWILLO) ---
TWILLO_ACCOUNT_SSD=
TWILLO_AUTH_TOKEN=
TWILLO_SERVICE_SID=
